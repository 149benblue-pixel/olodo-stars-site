{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "A football player in the club",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "photo": { "type": "string", "format": "uri" },
        "name": { "type": "string" },
        "number": { "type": "number" },
        "position": { "type": "string", "enum": ["Goalkeeper", "Defender", "Midfielder", "Striker"] },
        "matchesPlayed": { "type": "number" },
        "goals": { "type": "number" },
        "assists": { "type": "number" },
        "cleanSheets": { "type": "number" },
        "rating": { "type": "number" },
        "bio": { "type": "string" },
        "origin": { "type": "string" },
        "joinedDate": { "type": "string", "format": "date-time" },
        "commitmentCount": { "type": "number" }
      },
      "required": ["name", "number", "position"]
    },
    "Opinion": {
      "title": "Opinion",
      "description": "A fan opinion about a player",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "author": { "type": "string" },
        "text": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["author", "text", "date"]
    },
    "Official": {
      "title": "Official",
      "description": "A club official or staff member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "photo": { "type": "string", "format": "uri" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "contact": { "type": "string" }
      },
      "required": ["name", "role"]
    },
    "Match": {
      "title": "Match",
      "description": "A football match (past or upcoming)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "opponent": { "type": "string" },
        "score": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "competition": { "type": "string" },
        "isUpcoming": { "type": "boolean" },
        "venue": { "type": "string" },
        "time": { "type": "string" },
        "videoUrl": { "type": "string", "format": "uri" }
      },
      "required": ["opponent", "date", "isUpcoming"]
    },
    "News": {
      "title": "News",
      "description": "Club news and announcements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "image": { "type": "string", "format": "uri" },
        "approved": { "type": "boolean", "description": "Whether the post has been approved by an admin" }
      },
      "required": ["title", "content", "date", "approved"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A donation from a fan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "donorName": { "type": "string" },
        "amount": { "type": "number" },
        "message": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "date"]
    },
    "TeamStats": {
      "title": "TeamStats",
      "description": "Aggregated team performance statistics",
      "type": "object",
      "properties": {
        "totalMatches": { "type": "number" },
        "wins": { "type": "number" },
        "draws": { "type": "number" },
        "losses": { "type": "number" },
        "goalsScored": { "type": "number" },
        "goalsConceded": { "type": "number" },
        "averageRating": { "type": "number" }
      }
    },
    "GalleryImage": {
      "title": "GalleryImage",
      "description": "An image in the club gallery",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "caption": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "date"]
    },
    "User": {
      "title": "User",
      "description": "A user profile with role permissions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "editor", "viewer"] },
        "displayName": { "type": "string" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user permissions"
    },
    "/players/{playerId}": {
      "schema": "Player",
      "description": "Collection of players"
    },
    "/players/{playerId}/opinions/{opinionId}": {
      "schema": "Opinion",
      "description": "Subcollection of fan opinions for a player"
    },
    "/officials/{officialId}": {
      "schema": "Official",
      "description": "Collection of officials"
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of matches"
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Collection of news articles"
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Collection of donations"
    },
    "/gallery/{imageId}": {
      "schema": "GalleryImage",
      "description": "Collection of gallery images"
    },
    "/settings/teamStats": {
      "schema": "TeamStats",
      "description": "Global team statistics"
    }
  }
}
