rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Auth tokens can contain the email and its verification status
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function currentUserEmail() {
      return request.auth.token.email;
    }

    // Super Admin check: Hardcoded fallback + Database role
    function isSuperAdmin() {
      return isSignedIn() && (
        (currentUserEmail() == "149benblue@gmail.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')
      );
    }

    // Editor check: Role in database or Super Admin
    function isEditor() {
      return isSignedIn() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'editor')
      );
    }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidPlayer(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.number is number && data.number >= 0 && data.number <= 99 &&
             data.position is string && data.position.size() > 0 &&
             (data.get('photo', '') is string) &&
             (data.get('commitmentCount', 0) is number);
    }

    function isValidOfficial(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role is string && data.role.size() > 0 &&
             (data.get('photo', '') is string);
    }

    function isValidMatch(data) {
      return data.opponent is string && data.opponent.size() > 0 &&
             data.isUpcoming is bool &&
             (data.get('score', '') is string);
    }

    function isValidNews(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 &&
             data.approved is bool &&
             (data.get('image', '') is string) &&
             (data.get('date', request.time) == request.time);
    }

    function isValidGallery(data) {
      return data.url is string && data.url.size() > 0 &&
             (data.get('caption', '') is string) &&
             (data.get('date', request.time) == request.time);
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() > 0 &&
             data.role in ['super_admin', 'editor', 'viewer'] &&
             (data.get('displayName', null) == null || data.get('displayName', null) is string) &&
             (data.get('isPreAuthorized', false) is bool) &&
             (data.get('createdAt', request.time) == request.time);
    }

    function isValidDonation(data) {
      return data.amount is number && data.amount > 0 &&
             (data.get('donorName', '') is string) &&
             (data.get('message', '') is string) &&
             (data.get('date', request.time) == request.time);
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    // Users & Roles
    match /users/{userId} {
      // Allow users to get their own profile or their pre-auth record
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (resource != null && resource.data.email == currentUserEmail())
      );
      
      allow list: if isSuperAdmin();
      
      allow create: if (isSuperAdmin() && isValidUser(incoming())) || (
        isSignedIn() && request.auth.uid == userId && 
        isValidUser(incoming()) && 
        incoming().role == 'viewer' &&
        incoming().email == currentUserEmail()
      );
      
      allow update: if isSuperAdmin() && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'email', 'isPreAuthorized'])
      );
      
      allow delete: if isSuperAdmin() || (isSignedIn() && resource != null && resource.data.email == currentUserEmail() && userId.startsWith('pre_'));
    }

    // Players
    match /players/{playerId} {
      allow get: if true;
      allow list: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if (
        (isSuperAdmin() && isValidPlayer(incoming())) ||
        (isEditor() && isValidPlayer(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photo', 'bio', 'position', 'number'])) ||
        (isSignedIn() && 
         incoming().diff(existing()).affectedKeys().hasOnly(['commitmentCount']) &&
         incoming().commitmentCount == existing().commitmentCount + 1)
      );

      match /opinions/{opinionId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                        incoming().author is string && incoming().author.size() > 0 &&
                        incoming().text is string && incoming().text.size() > 0;
        allow update, delete: if isSuperAdmin();
      }
    }

    // Officials
    match /officials/{officialId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if (
        (isSuperAdmin() && isValidOfficial(incoming())) ||
        (isEditor() && isValidOfficial(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'photo', 'role', 'contact']))
      );
    }

    // Matches
    match /matches/{matchId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if (
        (isSuperAdmin() && isValidMatch(incoming())) ||
        (isEditor() && isValidMatch(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['score', 'videoUrl', 'venue', 'time', 'isUpcoming']))
      );
    }

    // News
    match /news/{newsId} {
      allow read: if true;
      allow create: if (
        (isEditor() && isValidNews(incoming())) ||
        (isSignedIn() && isValidNews(incoming()) && incoming().approved == false)
      );
      allow update: if (
        (isSuperAdmin() && isValidNews(incoming())) ||
        (isEditor() && isValidNews(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'image', 'approved']))
      );
      allow delete: if isSuperAdmin();
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow create, delete: if isSuperAdmin();
      allow update: if (
        (isSuperAdmin() && isValidGallery(incoming())) ||
        (isEditor() && isValidGallery(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['url', 'caption']))
      );
    }

    // Donations
    match /donations/{donationId} {
      allow list, get: if isSuperAdmin();
      allow create: if isValidDonation(incoming());
      allow update, delete: if isSuperAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }
  }
}
